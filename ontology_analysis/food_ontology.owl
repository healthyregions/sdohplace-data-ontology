        <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">food-price</rdfs:label>
        <skos:altLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">food-cost</skos:altLabel>
        <skos:altLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">food-prices</skos:altLabel>
        <skos:closeMatch rdf:resource="https://doi.org/10.1007/s13668-022-00428-x"/>
        <skos:definition xml:lang="en">Amount of money needed to acquire food</skos:definition>
    </owl:Class>
    


    <!-- http://webprotege.stanford.edu/RVSbmrGqkiskbeSMKoCxkK -->

    <owl:Class rdf:about="http://webprotege.stanford.edu/RVSbmrGqkiskbeSMKoCxkK">
