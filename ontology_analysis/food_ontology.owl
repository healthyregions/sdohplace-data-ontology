    <!-- http://webprotege.stanford.edu/RkxtBBIUgNSKmnMWjv9qUv -->

    <owl:Class rdf:about="http://webprotege.stanford.edu/RkxtBBIUgNSKmnMWjv9qUv">
        <rdfs:subClassOf rdf:resource="http://webprotege.stanford.edu/RDRtO7LX29GEjKqugWHg5zs"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://webprotege.stanford.edu/RDodSjUu6sbZI4mp3HrnDXX"/>
