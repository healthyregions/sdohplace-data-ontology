        <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">school-food-environment</rdfs:label>
        <skos:definition xml:lang="en">the spaces and conditions inside and around schools where food is available, obtained, or consumed</skos:definition>
