        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://webprotege.stanford.edu/RU407W4yhjiSzrxHJZI5Z8"/>
                <owl:someValuesFrom rdf:resource="http://webprotege.stanford.edu/R9KgTb8O0EmdfQoeP54K0n9"/>
            </owl:Restriction>
        </rdfs:subClassOf>
