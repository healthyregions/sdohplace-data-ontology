        <webprotege:RCX2gCumVjLzYmO9MyAGLdD rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MeSH:D000070497</webprotege:RCX2gCumVjLzYmO9MyAGLdD>
        <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">healthy-lifestyle-environment</rdfs:label>
        <skos:definition xml:lang="en">The environment that shapes pattern of behavior involving LIFE STYLE choices which ensure optimum health.</skos:definition>
    </owl:Class>
    


