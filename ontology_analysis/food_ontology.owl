        <skos:closeMatch rdf:resource="http://id.nlm.nih.gov/mesh/D000084884"/>
        <skos:definition xml:lang="en">Limited or uncertain availability of nutritionally adequate and safe foods or limited or uncertain ability to acquire acceptable foods in safe and socially acceptable ways, within an environment.</skos:definition>
    </owl:Class>
    


