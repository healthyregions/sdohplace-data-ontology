        <webprotege:RCX2gCumVjLzYmO9MyAGLdD rdf:datatype="http://www.w3.org/2001/XMLSchema#string">GSSO:012774</webprotege:RCX2gCumVjLzYmO9MyAGLdD>
        <rdfs:label>housing</rdfs:label>
